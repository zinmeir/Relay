# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional (defaults shown) ─────────────────────────────────────────────────
GATEWAY_PORT=8000

# Per-request HTTP timeout for upstream provider calls (seconds)
PROVIDER_TIMEOUT_SECS=30

# Maximum number of responses held in the in-memory cache
CACHE_MAX_CAPACITY=10000

# Cache entry time-to-live (seconds); responses older than this are evicted
CACHE_TTL_SECS=3600

# Tracing filter directives (https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=llm_gateway=debug,tower_http=debug,moka=info
